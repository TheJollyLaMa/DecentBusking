# DecentBusking Jukebox Bot — environment variables
# Copy this file to .env and fill in the values before running the bot.

# ── Discord ───────────────────────────────────────────────────────────────────
# Bot token from the Discord Developer Portal (https://discord.com/developers/applications)
DISCORD_TOKEN=your-discord-bot-token-here

# Numeric ID of the #jukebox channel the bot should watch for audio uploads.
# Enable Developer Mode in Discord (Settings → Advanced → Developer Mode),
# then right-click the channel and choose "Copy Channel ID".
JUKEBOX_CHANNEL_ID=123456789012345678

# ── IPFS / w3up ───────────────────────────────────────────────────────────────
# Server-side agent key and proof for headless w3up uploads.
#
# 1. Install the CLI:        npm install -g @web3-storage/w3cli
# 2. Create an agent key:    w3 key create
#    Copy the "key" value (starts with "Mg...") → W3UP_KEY
# 3. Create a proof:         w3 delegation create <agent-did> --can 'store/add' --can 'upload/add' | base64
#    → W3UP_PROOF
W3UP_KEY=MgCZ...your-ed25519-private-key...
W3UP_PROOF=MoAI...your-base64-ucan-proof...

# ── DecentBusking site ────────────────────────────────────────────────────────
# The bot appends ?title=<track>&ipfs=<CID> to this URL when building the mint link.
# Default: https://thejollylama.github.io/DecentBusking
SITE_URL=https://thejollylama.github.io/DecentBusking

# ── IPFS gateway ─────────────────────────────────────────────────────────────
# HTTP gateway used to list directory contents and stream tracks for /radio and /jukebox.
# Default: https://w3s.link  (web3.storage public gateway)
# Other options: https://ipfs.io  https://cloudflare-ipfs.com  https://dweb.link
IPFS_GATEWAY=https://w3s.link

# ── FFmpeg ────────────────────────────────────────────────────────────────────
# Path to the ffmpeg binary used for audio transcoding in /radio mode.
# If ffmpeg is on your system PATH you can leave this unset.
# Example: FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFMPEG_PATH=ffmpeg
